---
// GitHubアイコン (SVGインライン)
// SNSリンクはハードコードで管理。将来的にsrc/data/profile.tsに移行可能。
const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/ubow',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
    </svg>`,
  },
];
---

<section
  class="min-h-[calc(100vh-64px)] flex items-center justify-center px-4 py-16"
  aria-label="ヒーローセクション"
>
  <div class="max-w-2xl mx-auto text-center">
    <!-- 名前 -->
    <h1 class="text-5xl font-bold text-gray-800 mb-3 tracking-tight animate-fade-up">
      Your Name
    </h1>

    <!-- 職種 -->
    <p class="text-xl font-medium text-primary mb-6 animate-fade-up [animation-delay:150ms]">
      Backend Engineer
    </p>

    <!-- 自己紹介文 -->
    <p class="text-base text-gray-600 leading-relaxed mb-10 max-w-lg mx-auto animate-fade-up [animation-delay:300ms]">
      Go・Python を主軸にバックエンド開発7年。<br />
      スケーラブルなAPIとデータ基盤の設計・実装が得意です。<br />
      技術的な知見をブログで発信しています。
    </p>

    <!-- SNSリンク -->
    <div class="flex items-center justify-center gap-4 animate-fade-up [animation-delay:450ms]">
      {socialLinks.map(link => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.label}
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-200 text-gray-700 hover:border-primary hover:text-primary hover:-translate-y-0.5 hover:shadow-md transition-all text-sm font-medium"
        >
          <Fragment set:html={link.icon} />
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>
