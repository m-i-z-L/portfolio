---
import { career } from '../../data/career';

// "YYYY-MM" → "YYYY年M月" に変換する
function formatDate(ym: string): string {
  const [year, month] = ym.split('-');
  return `${year}年${parseInt(month, 10)}月`;
}

// 新しい順（startDate 降順）でソートする
const sortedCareer = [...career].sort((a, b) => b.startDate.localeCompare(a.startDate));
---

<section class="py-16 px-4 bg-white" aria-labelledby="career-heading">
  <div class="max-w-4xl mx-auto">
    <h2
      id="career-heading"
      class="text-3xl font-semibold text-gray-800 mb-12 text-center"
    >
      Career History
    </h2>

    <ol class="relative border-l-2 border-gray-200 ml-4 flex flex-col gap-10">
      {sortedCareer.map((entry, i) => (
        <li class="pl-8 relative animate-on-scroll" data-delay={i * 100}>
          {/* タイムラインドット */}
          <span
            class="absolute -left-[11px] top-1 w-5 h-5 rounded-full bg-primary border-2 border-white shadow"
            aria-hidden="true"
          />

          {/* カードヘッダー */}
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
            <h3 class="text-lg font-semibold text-gray-800">
              {entry.company}
            </h3>
            <p class="text-sm text-gray-500 shrink-0">
              <time datetime={entry.startDate}>{formatDate(entry.startDate)}</time>
              {' – '}
              {entry.endDate
                ? <time datetime={entry.endDate}>{formatDate(entry.endDate)}</time>
                : <span>現在</span>
              }
            </p>
          </div>

          {/* 役職 */}
          <p class="text-sm font-medium text-primary mb-2">{entry.role}</p>

          {/* 担当業務の概要 */}
          <p class="text-sm text-gray-600 leading-relaxed mb-4">{entry.description}</p>

          {/* 主な実績 */}
          <ul class="flex flex-col gap-1.5 mb-4" aria-label="主な実績">
            {entry.achievements.map(achievement => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="mt-1 shrink-0 w-1.5 h-1.5 rounded-full bg-primary" aria-hidden="true" />
                {achievement}
              </li>
            ))}
          </ul>

          {/* 使用技術タグ */}
          <ul class="flex flex-wrap gap-1.5" aria-label="使用技術">
            {entry.technologies.map(tech => (
              <li class="text-xs bg-blue-50 text-blue-700 border border-blue-100 rounded px-2 py-0.5 font-medium">
                {tech}
              </li>
            ))}
          </ul>

          {/* 参画プロジェクト（折りたたみ） */}
          {entry.projects && entry.projects.length > 0 && (
            <details class="mt-5 group">
              <summary class="flex items-center gap-2 cursor-pointer list-none [&::-webkit-details-marker]:hidden w-fit">
                <svg
                  class="w-3.5 h-3.5 text-gray-400 transition-transform duration-200 group-open:rotate-90"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                </svg>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">
                  参画プロジェクト ({entry.projects.length}件)
                </span>
              </summary>
              <ul class="flex flex-col gap-3 mt-3">
                {entry.projects.map(project => (
                  <li class="bg-gray-50 border border-gray-100 rounded-lg px-4 py-3">
                    <p class="text-sm font-semibold text-gray-800 mb-1">{project.name}</p>
                    <p class="text-xs text-gray-500 mb-2">
                      {project.role}
                      {project.teamSize !== undefined && (
                        <span> &nbsp;/&nbsp; チーム {project.teamSize} 名</span>
                      )}
                    </p>
                    <p class="text-xs text-gray-600 leading-relaxed mb-2">{project.description}</p>
                    {project.achievements && project.achievements.length > 0 && (
                      <ul class="flex flex-col gap-1 mb-2" aria-label="プロジェクト成果">
                        {project.achievements.map(achievement => (
                          <li class="flex items-start gap-1.5 text-xs text-gray-700">
                            <span class="mt-1 shrink-0 w-1 h-1 rounded-full bg-gray-400" aria-hidden="true" />
                            {achievement}
                          </li>
                        ))}
                      </ul>
                    )}
                    {project.technologies && project.technologies.length > 0 && (
                      <ul class="flex flex-wrap gap-1" aria-label="プロジェクト使用技術">
                        {project.technologies.map(tech => (
                          <li class="text-xs bg-white text-gray-600 border border-gray-200 rounded px-1.5 py-0.5">
                            {tech}
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            </details>
          )}
        </li>
      ))}
    </ol>
  </div>
</section>
